{
  "productName": "RigTree Fetch",
  "version": "0.1.0",
  "identifier": "dev.rigtree.fetch",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RigTree Fetch",
        "width": 1100,
        "height": 750,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["rigtree"]
      },
      "mobile": [
        {
          "scheme": ["rigtree"],
          "appLink": false
        }
      ]
    }
  }
}
